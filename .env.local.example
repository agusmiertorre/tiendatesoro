# Copiá este archivo a ".env.local" (sin el ".example") y completá con tus valores reales.
# El archivo ".env.local" NUNCA se sube a GitHub (ya está en .gitignore).

# Estos dos son públicos, se usan también en el navegador:
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Este es SECRETO, solo se usa en el servidor (API routes), nunca en el navegador:
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
